{
  "manifest_version": 3,
  "name": "TrendNow - Google Trends Scanner",
  "version": "1.0.0",
  "description": "Spot rising trends & keywords before they explode. Clean & fast Chrome extension.",
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "TrendNow"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://trends.google.com/*", "*://www.youtube.com/*"],
      "js": ["content.js"]
    }
  ],
  "permissions": [
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://trends.google.com/*",
    "https://suggestqueries.google.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'"
  }
}